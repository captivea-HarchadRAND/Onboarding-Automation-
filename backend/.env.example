# ─── Mode développement (sans Azure) ──────────────────────────────────────────
# Mettre à true pour simuler toutes les appels Graph API avec des données fictives.
# Aucun compte Microsoft 365 réel ne sera créé.
MOCK_GRAPH=false

# Pour simuler un échec à une étape précise et tester le rollback :
#   MOCK_FAIL_STEP=1  →  échec création compte AD
#   MOCK_FAIL_STEP=2  →  échec ajout groupe (rollback déclenché)
#   MOCK_FAIL_STEP=3  →  échec assignation licence (rollback déclenché)
MOCK_FAIL_STEP=0

# Durée simulée de chaque étape en millisecondes (défaut : 1200)
MOCK_DELAY_MS=1200

# ─── Azure AD / Graph API (ignoré si MOCK_GRAPH=true) ─────────────────────────
AZURE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_CLIENT_SECRET=your-secret-here

# Mot de passe temporaire du nouvel employé (forceChangePasswordNextSignIn = true)
DEFAULT_PASSWORD=TempPass@2024!

# Domaine utilisé si l'email n'est pas saisi manuellement
DEFAULT_DOMAIN=monentreprise.com

# Code pays ISO 3166-1 alpha-2 — requis pour l'assignation de licence
USAGE_LOCATION=FR

# Serveur
PORT=8081
FRONTEND_URL=http://localhost:5174
COOKIE_SECURE=false

# Compte admin créé au premier démarrage (si aucun admin n'existe)
ADMIN_INITIAL_EMAIL=admin@monentreprise.com
ADMIN_INITIAL_PASSWORD=
